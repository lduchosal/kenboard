# Database host
DB_HOST=localhost
DB_PORT=3306

# App runtime (CRUD only)
DB_USER=dashboard
DB_PASSWORD=changeme

# Migrations (DDL: CREATE, ALTER, DROP)
DB_MIGRATE_USER=dashboard_admin
DB_MIGRATE_PASSWORD=changeme

# App database
DB_NAME=dashboard

# Test runtime (CRUD only)
DB_TEST_USER=dashboard_test
DB_TEST_PASSWORD=changeme

# Test migrations (DDL on test DB)
DB_TEST_MIGRATE_USER=dashboard_test_admin
DB_TEST_MIGRATE_PASSWORD=changeme

# Test database
DB_TEST_NAME=dashboard_test

# Dev mode toggle. In prod, set DEBUG=false — this also makes
# KENBOARD_SECRET_KEY mandatory (the app will refuse to boot without).
DEBUG=true

# -- Security ----------------------------------------------------------------

# Flask session signing key. REQUIRED in prod (DEBUG=false). Generate with:
#   python -c "import secrets; print(secrets.token_urlsafe(48))"
# Rotate to invalidate every active cookie session at once.
KENBOARD_SECRET_KEY=

# Static admin bearer token for /api/v1/* (cf. doc/api-keys.md). Required
# to bootstrap the first admin user via the API and to call admin-only
# endpoints from CLI / CI. Generate with:
#   python -c "import secrets; print('kb_' + secrets.token_urlsafe(32))"
# Leave empty to disable bearer-token admin auth (cookie session only).
KENBOARD_ADMIN_KEY=

# CORS allow-list for /api/v1/* — comma-separated origins. Leave empty
# to disable CORS entirely (browsers fall back to same-origin policy,
# which is the secure default for the built-in templates served by
# Flask). Only set this when an external client needs the API.
KENBOARD_CORS_ORIGINS=

# Set to true when serving over HTTPS (directly or behind a TLS-terminating
# reverse proxy). Enables Secure cookies and HSTS. Leave false in local dev
# over HTTP, otherwise the browser drops the session cookie.
KENBOARD_HTTPS=false

# -- OIDC (optional) --------------------------------------------------------
# When all three are set, the login page shows a "Sign in with OIDC" button.
# Leave empty to disable OIDC entirely (password-only login).
#
# Discovery URL for the IdP (e.g. Authentik, Google, ADFS):
#   Google:    https://accounts.google.com/.well-known/openid-configuration
#   Authentik: https://sso.example.com/application/o/<app>/.well-known/openid-configuration
#   ADFS:      https://adfs.example.local/adfs/.well-known/openid-configuration
OIDC_DISCOVERY_URL=
OIDC_CLIENT_ID=
OIDC_CLIENT_SECRET=

# Restrict OIDC logins to a specific email domain (optional).
# Leave empty to accept any email the IdP returns.
# OIDC_ALLOWED_EMAIL_DOMAIN=example.com

# ADFS does not emit `email_verified`. Set to false to trust the IdP's
# email unconditionally. Default: true.
# OIDC_REQUIRE_EMAIL_VERIFIED=false

# OIDC scopes. Default: "openid email profile" (Google, Authentik).
# For ADFS use "openid profile allatclaims" (no `email` scope in ADFS).
# OIDC_SCOPES=openid profile allatclaims
