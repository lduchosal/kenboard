coverage/
dist/
# Re-include the Vite-bundled frontend so Python-only contributors don't
# need Node to run the app (#251). The bundle is small and rebuilt on
# every release via publish.sh.
!src/dashboard/static/dist/
node_modules/
build/
*.egg-info/
.eggs/
.venv/
.env
.tox/
pdm.lock
logs/
KENBOARD.md
.ken
.ken2
.ken3
.ken*

# Signed Firefox .xpi artifacts (web-ext sign) — account-bound, regenerated
# on demand by scripts/sign-firefox-extension.sh, never committed. Kept at
# the repo root (not under extension/) so they never land in the release zip.
/web-ext-artifacts/
# AMO API credentials sourced by scripts/sign-firefox-extension.sh — account
# secrets. Repo root, never under extension/ (which is zipped into releases).
/.amo-credentials
# web-ext writes this add-on UUID marker into the source dir on sign; keep it
# local (helps future re-signs map to the same add-on) but never commit/ship.
extension/.amo-upload-uuid

# OS / editor noise (#293)
.DS_Store
Thumbs.db
*.swp
.vscode/
# HTML output is fully derived from /wiki/ — regenerated on demand by
# `ken wiki build`. /wiki/ itself is committed (#376) as a human-
# readable snapshot of the kanban board's classifications.
/wiki-html/
