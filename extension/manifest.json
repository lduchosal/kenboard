{
  "manifest_version": 3,
  "name": "kenboard quick-task",
  "version": "0.1.113",
  "description": "Capture the current tab as a kenboard task with one keystroke.",
  "permissions": ["storage", "activeTab"],
  "host_permissions": ["<all_urls>"],
  "action": {
    "default_popup": "popup.html",
    "default_title": "Quick task to kenboard"
  },
  "options_page": "options.html",
  "commands": {
    "_execute_action": {
      "suggested_key": {
        "default": "Ctrl+Shift+K",
        "mac": "Command+Shift+K"
      },
      "description": "Open quick-task popup"
    }
  }
}
