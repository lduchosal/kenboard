{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "checkJs": false,
    "noEmit": true,
    "allowJs": true,
    "lib": ["DOM", "DOM.Iterable", "ES2022"],
    "noImplicitAny": false,
    "strictNullChecks": false,
    "skipLibCheck": true
  },
  "include": ["src/dashboard/static/js/**/*.js"],
  "exclude": ["src/dashboard/static/dist/**", "node_modules/**"]
}
